# Normalise all text files to LF on commit (CRLF in git objects breaks
# Dockerfile RUN heredocs, nginx config parsing, and bash scripts on Linux).
* text=auto eol=lf

# Explicitly treat these as text with LF regardless of content-sniffing
*.sh      text eol=lf
*.py      text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.conf    text eol=lf
*.md      text eol=lf
*.txt     text eol=lf
*.html    text eol=lf
*.css     text eol=lf
*.js      text eol=lf
*.json    text eol=lf
Dockerfile text eol=lf
Pipfile   text eol=lf

# Binary files — never touch line endings
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.woff    binary
*.woff2   binary
*.ttf     binary
*.eot     binary
*.otf     binary
*.zip     binary
*.gz      binary
*.tar     binary
*.lock    text eol=lf
