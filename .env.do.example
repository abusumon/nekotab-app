# .env.do.example — DigitalOcean production environment template
#
# Copy this file to .env on your Droplet under /opt/nekotab/.env
# Fill in ALL values marked with <CHANGE_ME> before deploying.
#
#   cp .env.do.example /opt/nekotab/.env
#   chmod 600 /opt/nekotab/.env   # restrict to root/deploy user only
#   nano /opt/nekotab/.env
#
# This file is loaded automatically by docker compose (via --env-file or the
# default .env in the same directory as docker-compose.do.yml).

# ---------------------------------------------------------------------------
# Container Registry  (DigitalOcean Container Registry)
# Create at: https://cloud.digitalocean.com/registry
# ---------------------------------------------------------------------------
DO_REGISTRY_URL=registry.digitalocean.com/<CHANGE_ME: your-registry-name>
IMAGE_TAG=latest

# ---------------------------------------------------------------------------
# Django core
# Generate a secret key with: python -c "import secrets; print(secrets.token_hex(50))"
# ---------------------------------------------------------------------------
DJANGO_SECRET_KEY=<CHANGE_ME: generate a strong 50+ char secret key>
ON_DIGITALOCEAN=1
DEBUG=0

# Public base URL used for OAuth callback construction and canonical links.
SITE_BASE_URL=https://nekotab.app

# Comma-separated list of allowed hosts.
# Must include your domain, wildcard subdomain, localhost loopback hosts
# (for internal container health checks), and the Droplet's public IP.
ALLOWED_HOSTS=.nekotab.app,nekotab.app,localhost,127.0.0.1,168.144.129.248

# Set to 'disable' ONLY during initial staging smoke-tests without a DO Load Balancer.
# Remove or leave empty for real production.
DISABLE_HTTPS_REDIRECTS=

# ---------------------------------------------------------------------------
# Database  (self-hosted PostgreSQL in Docker on this Droplet)
# Use the hostname 'db' — that's the Docker Compose service name.
# Generate a password: python3 -c "import secrets; print(secrets.token_hex(24))"
# Replace YOUR_POSTGRES_PASSWORD in both lines below with the same value.
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD=<CHANGE_ME: generate a strong random password>
DATABASE_URL=postgresql://nekotab:<CHANGE_ME: same password as above>@db:5432/nekotab

# Connection pool tuning.
DB_CONN_MAX_AGE=60

# ---------------------------------------------------------------------------
# Redis  (self-hosted Redis in Docker on this Droplet)
# Uses the Docker Compose service name 'redis' — no password required.
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ---------------------------------------------------------------------------
# Worker concurrency
# Start at 2 on a 4 GiB Droplet and increase after measuring memory headroom.
# Safe range: 2 (conservative) → 4 (max for 4 GiB with all services running).
# ---------------------------------------------------------------------------
WEB_CONCURRENCY=2

# ---------------------------------------------------------------------------
# Subdomain routing
# ---------------------------------------------------------------------------
SUBDOMAIN_TOURNAMENTS_ENABLED=true
SUBDOMAIN_BASE_DOMAIN=nekotab.app
ORGANIZATION_WORKSPACES_ENABLED=true
RESERVED_SUBDOMAINS=www,admin,api,jet,database,static,media

# ---------------------------------------------------------------------------
# TLS certificates for apex + ALL tournament subdomains (wildcard)
#
# Use DNS-01 with Name.com API so one cert covers:
#   nekotab.app and *.nekotab.app
#
# Required once before enabling:
#   1) Create a Name.com API token in your Name.com account
#   2) Set NAMECOM_USERNAME and NAMECOM_API_TOKEN below
#   3) Run: /opt/nekotab/bin/renew-letsencrypt-do.sh
# ---------------------------------------------------------------------------
LETSENCRYPT_WILDCARD=true
LETSENCRYPT_BASE_DOMAIN=nekotab.app
LETSENCRYPT_CERT_NAME=nekotab.app
LETSENCRYPT_DOMAINS=nekotab.app,*.nekotab.app
LETSENCRYPT_EMAIL=support@nekotab.app

# Name.com DNS API credentials used by certbot DNS hooks
NAMECOM_USERNAME=<CHANGE_ME: your-namecom-username>
NAMECOM_API_TOKEN=<CHANGE_ME: your-namecom-api-token>
NAMECOM_API_BASE_URL=https://api.name.com/v4
NAMECOM_DNS_PROPAGATION_SECONDS=45

# ---------------------------------------------------------------------------
# Google OAuth (Sign in with Google)
# In Google Cloud Console, add this Authorized redirect URI:
#   https://<YOUR_DOMAIN>/accounts/google/login/callback/
# ---------------------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=<CHANGE_ME: google-oauth-client-id>
GOOGLE_OAUTH_CLIENT_SECRET=<CHANGE_ME: google-oauth-client-secret>

# ---------------------------------------------------------------------------
# Email  (IMPORTANT: DO blocks SMTP ports 25/465/587 on Droplets)
# Use SendGrid, Mailgun, SES, Postmark, or another relay.
#
# Option A — Generic SMTP relay (e.g. SendGrid, Mailgun):
# ---------------------------------------------------------------------------
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=<CHANGE_ME: your-sendgrid-or-smtp-password>
EMAIL_USE_TLS=true
EMAIL_TIMEOUT=20
DEFAULT_FROM_EMAIL=NekoTab Team <support@nekotab.app>
SERVER_EMAIL=support@nekotab.app
REPLY_TO_EMAIL=support@nekotab.app

# Option B — SendGrid API key (if you prefer the SG-native method):
# SENDGRID_API_KEY=<CHANGE_ME: SG.xxxx>

# ---------------------------------------------------------------------------
# Nekospeech / Nekocongress auxiliary services
# By default these inherit DATABASE_URL and REDIS_URL from above.
# Override here only if you want them to use a separate DB/cache.
# ---------------------------------------------------------------------------
# NEKOSPEECH_DATABASE_URL=
# NEKOSPEECH_REDIS_URL=
# NEKOSPEECH_CELERY_BROKER_URL=
# NEKOSPEECH_JWT_SECRET_KEY=
# NEKOCONGRESS_DATABASE_URL=
# NEKOCONGRESS_REDIS_URL=
# NEKOCONGRESS_JWT_SECRET_KEY=

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
SENTRY_DSN=<CHANGE_ME: https://xxx@oXXX.ingest.sentry.io/YYY or leave blank>
DISABLE_SENTRY=

# ---------------------------------------------------------------------------
# Timezone
# ---------------------------------------------------------------------------
TIME_ZONE=UTC

# ---------------------------------------------------------------------------
# Tab Director contact email (shown in certain admin reports)
# ---------------------------------------------------------------------------
TAB_DIRECTOR_EMAIL=<CHANGE_ME: your-email@example.com>
