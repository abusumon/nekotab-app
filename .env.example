# ==============================================================================
# NekoTab — Environment Variables
# Copy this file to .env and fill in your values.
# ==============================================================================

# --- Django ---
# SECRET_KEY used by Django for cryptographic signing.
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-to-a-random-secret

# --- nekospeech ---
# Configuration for the nekospeech Individual Events (IE) microservice.
# All variables are prefixed with NEKOSPEECH_ (pydantic-settings env_prefix).

# Database connection for nekospeech.  MUST use the asyncpg driver scheme
# (postgresql+asyncpg://), NOT the plain postgresql:// scheme.
# Points to the SAME Postgres instance as Django; nekospeech owns the
# "speech_events" schema within that database.
NEKOSPEECH_DATABASE_URL=postgresql+asyncpg://NekoTab:NekoTab@db:5432/NekoTab

# Redis URL used by nekospeech for caching / pub-sub.
NEKOSPEECH_REDIS_URL=redis://redis:6379/2

# Celery broker + result backend (nekospeech worker).
NEKOSPEECH_CELERY_BROKER_URL=redis://redis:6379/3
NEKOSPEECH_CELERY_RESULT_BACKEND=redis://redis:6379/3

# JWT shared secret — must match Django's SECRET_KEY exactly so that tokens
# issued by Django are valid in nekospeech and vice-versa.
# Copy the value of DJANGO_SECRET_KEY here verbatim.
NEKOSPEECH_JWT_SECRET_KEY=change-me-to-a-random-secret

# JWT algorithm (default: HS256).  Only change if you also change Django.
NEKOSPEECH_JWT_ALGORITHM=HS256

# Set to true for verbose logging in development.
NEKOSPEECH_DEBUG=false

# Comma-separated list of allowed CORS origins for the nekospeech API.
NEKOSPEECH_CORS_ORIGINS=["http://localhost:8000","http://localhost:8080"]

# PostgreSQL schema name used for IE tables (default: speech_events).
# You should not need to change this unless you have a naming conflict.
NEKOSPEECH_SPEECH_EVENTS_SCHEMA=speech_events
